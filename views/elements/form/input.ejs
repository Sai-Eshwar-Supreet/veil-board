<%
  const { type = 'text', name, id = name, value = '', required } = locals;
%>

<%- include('elements/form/field', {
  ...locals,
  id,
  field: `
    <input
      class="input"
      type="${type}"
      id="${id}"
      name="${name}"
      value="${value}"
      ${required ? 'required' : ''}
    />
  `
}) %>