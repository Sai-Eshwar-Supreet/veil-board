<section class="posts-section">
    <%- include('../elements/headings/section-heading', { heading: 'Discussions' }) %>
    <ul class="posts-list">
        <% if(posts.length === 0){ %>
            <p>No posts yet...</p>
        <% } else { 
        posts.forEach(post => {%>
            <li class="post-card">
                <% if(locals.user){ %>
                    <a class="post-link" href="<%= `/posts/${post.id}/details`%>">
                        <%- include('../elements/headings/item-heading', { heading: post.title }) %>
                    </a>
                <% }
                else { %>
                    <%- include('../elements/headings/item-heading', { heading: post.title }) %>
                <%}%>
                <p class="post-content">
                    <%= 
                    post.content?.length > (locals.previewLength || 50)
                    ? `${post.content.slice(0, 50)}...`
                    : post.content
                    %>
                </p>
                <div class="post-meta <%= locals.user? 'show-meta' : 'hide-meta' %>">
                    <p class="post-author">
                        <%=
                        locals.user
                        ? post.author
                        : 'Anonymous'
                        %>
                    </p>
                    <p class="post-date">
                        <%=
                        locals.user? post.updatedAt ? post.updatedAt.toDateString() : post.createdAt.toDateString()  : '???'
                        %>
                    </p>
                </div>
                    
            </li>
        <%})%>
    </ul>
    <% } %>
</section>